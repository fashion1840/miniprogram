/* pages/editor/editor.wxss - Neo-Brutalism Style */

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #fff;
  overflow: hidden;
}

/* 顶部预览区 - Brutalism */
.preview-section {
  flex-shrink: 0;
  height: 50vh;
  background: #ff6b6b;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  padding: 40rpx 0;
  border-bottom: 6rpx solid #000;
}

.preview-container {
  width: 480rpx;
  background-color: #fff;
  border-radius: 0;
  border: 4rpx solid #000;
  box-shadow: 12rpx 12rpx 0 #000;
  position: relative;
  transition: all 0.2s;
  overflow: hidden;
}

/* 比例自适应 - 稍微调大预览尺寸 */
.preview-container.ratio-3-4 { width: 480rpx; height: 640rpx; }
.preview-container.ratio-1-1 { width: 480rpx; height: 480rpx; }
.preview-container.ratio-4-3 { width: 480rpx; height: 360rpx; }
.preview-container.ratio-9-16 { width: 360rpx; height: 640rpx; }

.preview-canvas {
  width: 100%;
  height: 100%;
}

.preview-hint {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #abb2bf;
  font-size: 26rpx;
  letter-spacing: 2rpx;
  pointer-events: none;
}

/* 空状态引导 - Brutalism */
.empty-state {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffe66d;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
}

.empty-state.show {
  opacity: 1;
  pointer-events: auto;
}

.empty-hint {
  font-size: 32rpx;
  color: #000;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 4rpx;
}

/* 编辑面板容器 - Brutalism */
.editor-container {
  flex: 1;
  background-color: #f8f9fa;
  border-top-left-radius: 0;
  border-top-right-radius: 0;
  overflow: hidden;
  z-index: 10;
}

.editor-scroll {
  height: 100%;
}

.editor-content {
  padding: 32rpx 0;
}

/* 卡片样式 - Brutalism */
.card {
  background-color: #fff;
  border-radius: 0;
  margin: 0 24rpx 24rpx;
  padding: 24rpx;
  border: 4rpx solid #000;
  box-shadow: 8rpx 8rpx 0 #000;
  position: relative;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: 900;
  color: #000;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.card-subtitle {
  font-size: 26rpx;
  color: #94a3b8;
  font-weight: 500;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.action-btns {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.reset-btn {
  padding: 8rpx 20rpx;
  background: #ffe66d;
  border-radius: 0;
  border: 3rpx solid #000;
  box-shadow: 4rpx 4rpx 0 #000;
  transition: all 0.1s;
}

.reset-btn:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 #000;
}

.reset-text {
  font-size: 24rpx;
  color: #000;
  font-weight: 900;
}

.clear-btn {
  width: 44rpx;
  height: 44rpx;
  background-color: #ff6b6b;
  border-radius: 0;
  border: 3rpx solid #000;
  box-shadow: 4rpx 4rpx 0 #000;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.1s;
}

.clear-btn:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 #000;
}

.clear-icon {
  font-size: 28rpx;
  color: #000;
  font-weight: 900;
}

.clear-btn:active {
  background-color: #cbd5e1;
}

.clear-icon {
  font-size: 28rpx;
  color: #64748b;
  font-weight: 500;
  line-height: 1;
}

/* 文字输入框 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.icon-box {
  width: 56rpx;
  height: 56rpx;
  background: #000;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #000;
}

.markdown-toolbar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  border: 3rpx solid #000;
  border-radius: 12rpx;
  padding: 8rpx 12rpx;
  box-shadow: 3rpx 3rpx 0 #000;
}

.toolbar-btn {
  width: 60rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  font-size: 28rpx;
  font-weight: 700;
  color: #000;
  border-radius: 8rpx;
  transition: all 0.15s ease;
  letter-spacing: 2rpx;
}

.toolbar-btn:active {
  background: #f0f0f0;
}

.toolbar-btn.bold {
  font-weight: 900;
}

.toolbar-btn.italic {
  font-style: italic;
  font-family: Georgia, serif;
  transform: skewX(-8deg);
}

.toolbar-btn.underline {
  text-decoration: underline;
  text-underline-offset: 6rpx;
}

.toolbar-btn.link {
  font-size: 24rpx;
}

.toolbar-btn.highlight {
  position: relative;
}

.highlight-icon {
  position: relative;
  width: 30rpx;
  height: 30rpx;
  transform: rotate(-35deg);
}

.highlight-brush-handle {
  position: absolute;
  left: 4rpx;
  top: 11rpx;
  width: 14rpx;
  height: 7rpx;
  border: 3rpx solid #000;
  border-radius: 7rpx;
  background: #fff;
}

.highlight-brush-ferrule {
  position: absolute;
  left: 18rpx;
  top: 10rpx;
  width: 6rpx;
  height: 9rpx;
  border: 3rpx solid #000;
  border-left: none;
  border-radius: 0 3rpx 3rpx 0;
  background: #fff;
}

.highlight-brush-head {
  position: absolute;
  left: 24rpx;
  top: 9rpx;
  width: 0;
  height: 0;
  border-top: 6rpx solid transparent;
  border-bottom: 6rpx solid transparent;
  border-left: 8rpx solid #000;
}




.textarea-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.markdown-hint {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

.footer-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.char-count {
  font-size: 24rpx;
  color: #000;
  font-weight: 600;
}

.text-btn {
  padding: 10rpx 28rpx;
  font-size: 26rpx;
  font-weight: 700;
  border: 3rpx solid #000;
  border-radius: 8rpx;
  box-shadow: 3rpx 3rpx 0 #000;
  transition: all 0.1s ease;
}

.text-btn.reset {
  background: #fff;
  color: #000;
}

.text-btn.clear {
  background: #000;
  color: #fff;
}

.text-btn:active {
  transform: translate(3rpx, 3rpx);
  box-shadow: 0 0 0 #000;
}

.textarea-wrapper {
  background-color: #fff;
  border-radius: 0;
  padding: 24rpx;
  border: 3rpx solid #000;
  box-shadow: 4rpx 4rpx 0 #000;
}

.main-textarea {
  width: 100%;
  height: 240rpx;
  font-size: 32rpx;
  line-height: 1.6;
  color: #000;
  font-weight: 500;
}

/* 选项网格 (比例选择) */
.option-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.option-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  background-color: #fff;
  border-radius: 0;
  border: 3rpx solid #000;
  box-shadow: 4rpx 4rpx 0 #000;
  transition: all 0.1s;
}

.option-item.active {
  background-color: #ff6b6b;
  color: #000;
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 #000;
}

.ratio-icon {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #64748b;
  margin-bottom: 14rpx;
  border-radius: 6rpx;
}

.option-item.active .ratio-icon { border-color: #4facfe; }

.ratio-icon-1-1 { width: 32rpx; height: 32rpx; }
.ratio-icon-3-4 { width: 32rpx; height: 42rpx; }
.ratio-icon-4-3 { width: 42rpx; height: 32rpx; }
.ratio-icon-9-16 { width: 26rpx; height: 46rpx; }

.option-item text {
  font-size: 26rpx;
  font-weight: 600;
}

/* 标签切换 (渐变/纯色/图片) */
.tab-pills {
  display: flex;
  background-color: #fff;
  padding: 4rpx;
  border-radius: 0;
  border: 3rpx solid #000;
  box-shadow: 4rpx 4rpx 0 #000;
}

.pill {
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  border-radius: 0;
  color: #000;
  transition: all 0.1s;
  font-weight: 700;
}

.pill.active {
  background-color: #ffe66d;
  color: #000;
  font-weight: 900;
}

/* 背景网格布局 */
.bg-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 16rpx 0;
  min-height: 140rpx;
}

.bg-grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx;
  border-radius: 0;
  border: 3rpx solid #000;
  background-color: #fff;
  box-shadow: 4rpx 4rpx 0 #000;
  transition: all 0.1s;
}

.bg-grid-item.active {
  border-color: #000;
  background-color: #4ecdc4;
  transform: translate(2rpx, 2rpx);
  box-shadow: 2rpx 2rpx 0 #000;
}

.gradient-preview, .color-preview {
  width: 100%;
  height: 100rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

/* 纹理预览 - 与渐变/纯色统一样式 */
.texture-preview {
  width: 100%;
  height: 100rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  position: relative;
  overflow: hidden;
}

/* 图片上传 - 3x3 大区域 */
.custom-upload-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 16rpx 0;
}

.custom-upload-item {
  grid-column: span 3;
  height: 400rpx;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  background-color: #f8fafc;
  transition: all 0.25s ease;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.custom-upload-item.active {
  border-color: #4facfe;
  background-color: #f0f9ff;
  box-shadow: 0 8rpx 20rpx rgba(79, 172, 254, 0.2);
}

.upload-placeholder-large {
  width: 100%;
  height: 100%;
  background-color: #f1f5f9;
  border: 3rpx dashed #cbd5e1;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  transition: all 0.25s ease;
}

.custom-upload-item:active .upload-placeholder-large {
  background-color: #e2e8f0;
  border-color: #4facfe;
}

.upload-icon-large {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid #94a3b8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  color: #94a3b8;
  font-weight: 300;
}

.upload-text {
  font-size: 32rpx;
  color: #64748b;
  font-weight: 500;
}

.upload-image-large {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
  object-fit: cover;
}

/* 自定义图片网格 - 与纹理网格保持一致 */
.custom-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 16rpx 0;
  min-height: 140rpx;
}

.custom-grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  background-color: #f8fafc;
  transition: all 0.25s ease;
}

.custom-grid-item.active {
  border-color: #4facfe;
  background-color: #f0f9ff;
  box-shadow: 0 8rpx 20rpx rgba(79, 172, 254, 0.2);
}

.custom-icon {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.icon-plus-small {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #64748b;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #64748b;
  font-weight: 300;
}

.custom-preview {
  width: 100%;
  height: 100rpx;
  border-radius: 12rpx;
  object-fit: cover;
  margin-bottom: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.custom-preview.active-border {
  border: 3rpx solid #4facfe;
}

.custom-label {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

.custom-grid-item.active .custom-label {
  color: #4facfe;
}

/* 纹理预览图案 - 在 100rpx x 100rpx 区域内展示 */
.preview-paper {
  width: 100%;
  height: 100%;
  background: #faf8f5;
  position: relative;
}
.preview-paper::before {
  content: '';
  position: absolute;
  top: 20rpx;
  left: 12rpx;
  right: 12rpx;
  height: 2rpx;
  background: rgba(0,0,0,0.1);
  box-shadow: 0 16rpx 0 rgba(0,0,0,0.1), 0 32rpx 0 rgba(0,0,0,0.1), 0 48rpx 0 rgba(0,0,0,0.1);
}

.preview-grid {
  width: 100%;
  height: 100%;
  background: 
    linear-gradient(90deg, transparent 48%, rgba(0,0,0,0.08) 48%, rgba(0,0,0,0.08) 52%, transparent 52%),
    linear-gradient(0deg, transparent 48%, rgba(0,0,0,0.08) 48%, rgba(0,0,0,0.08) 52%, transparent 52%);
  background-size: 25rpx 25rpx;
}

.preview-dots {
  width: 100%;
  height: 100%;
  background: #f5f5f5;
  position: relative;
}
.preview-dots::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: radial-gradient(circle, rgba(0,0,0,0.15) 3rpx, transparent 3rpx);
  background-size: 30rpx 30rpx;
}

.preview-horizontal {
  width: 100%;
  height: 100%;
  background: #fff;
  position: relative;
}
.preview-horizontal::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 18rpx,
    rgba(0,0,0,0.08) 18rpx,
    rgba(0,0,0,0.08) 20rpx
  );
}

.preview-diagonal {
  width: 100%;
  height: 100%;
  background: #fff;
  position: relative;
  overflow: hidden;
}
.preview-diagonal::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  right: -50%;
  bottom: -50%;
  background: repeating-linear-gradient(
    45deg,
    transparent,
    transparent 18rpx,
    rgba(0,0,0,0.08) 18rpx,
    rgba(0,0,0,0.08) 20rpx
  );
}

.preview-cross {
  width: 100%;
  height: 100%;
  background: #f8f8f8;
  position: relative;
}
.preview-cross::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 28rpx,
      rgba(0,0,0,0.1) 28rpx,
      rgba(0,0,0,0.1) 30rpx
    ),
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 28rpx,
      rgba(0,0,0,0.1) 28rpx,
      rgba(0,0,0,0.1) 30rpx
    );
}

.preview-vertical {
  width: 100%;
  height: 100%;
  background: #fff;
  position: relative;
}
.preview-vertical::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: repeating-linear-gradient(
    90deg,
    transparent,
    transparent 18rpx,
    rgba(0,0,0,0.08) 18rpx,
    rgba(0,0,0,0.08) 20rpx
  );
}

.preview-checkerboard {
  width: 100%;
  height: 100%;
  background: 
    linear-gradient(90deg, rgba(0,0,0,0.06) 50%, transparent 50%),
    linear-gradient(0deg, rgba(0,0,0,0.06) 50%, transparent 50%);
  background-size: 25rpx 25rpx;
}

.preview-noise {
  width: 100%;
  height: 100%;
  background: #f5f5f5;
  position: relative;
}
.preview-noise::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: radial-gradient(circle, rgba(0,0,0,0.2) 1.5rpx, transparent 1.5rpx);
  background-size: 8rpx 8rpx;
}

.preview-waves {
  width: 100%;
  height: 100%;
  background: #fafafa;
  position: relative;
  overflow: hidden;
}
.preview-waves::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 25rpx,
    rgba(0,0,0,0.08) 25rpx,
    rgba(0,0,0,0.08) 27rpx,
    transparent 27rpx,
    transparent 30rpx
  );
  border-radius: 0 0 50% 50% / 0 0 10rpx 10rpx;
}

.preview-hexagon {
  width: 100%;
  height: 100%;
  background: #f0f0f0;
  position: relative;
}
.preview-hexagon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 40rpx;
  height: 46rpx;
  background: rgba(0,0,0,0.1);
  transform: translate(-50%, -50%);
  clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  box-shadow: 30rpx 0 0 rgba(0,0,0,0.1), -30rpx 0 0 rgba(0,0,0,0.1);
}

.preview-dotgrid {
  width: 100%;
  height: 100%;
  background: #fff;
  position: relative;
}
.preview-dotgrid::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: radial-gradient(circle, rgba(0,0,0,0.12) 2rpx, transparent 2rpx);
  background-size: 25rpx 25rpx;
}

/* 字体颜色网格 */
.color-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 16rpx;
  padding: 16rpx 0;
}

.color-grid-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx;
  border-radius: 50%;
  border: 3rpx solid transparent;
  transition: all 0.1s;
  position: relative;
}

.color-grid-item.active {
  border-color: #000;
  background-color: #ff6b6b;
}

.color-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  box-shadow: none;
  border: 3rpx solid #000;
  position: relative;
}

/* 选中状态的勾选标记 */
.color-grid-item.active .color-circle::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 12rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: translate(-50%, -70%) rotate(-45deg);
  box-shadow: -2rpx 2rpx 4rpx rgba(0,0,0,0.2);
}

.bg-item-label {
  font-size: 20rpx;
  color: #000;
  text-align: center;
  font-weight: 700;
}

.bg-grid-item.active .bg-item-label {
  color: #000;
  font-weight: 900;
}

/* 上传区域 */
.upload-area {
  width: 100%;
  height: 240rpx;
  background-color: #fff;
  border-radius: 0;
  border: 3rpx dashed #000;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  transition: all 0.1s;
}

.upload-area:active {
  background-color: #ffe66d;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #94a3b8;
}

.icon-plus {
  font-size: 56rpx;
  margin-bottom: 12rpx;
  font-weight: 300;
}

.upload-preview {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
}

.upload-preview.active-border {
  border: 6rpx solid #4facfe;
  border-radius: 24rpx;
}

/* 分段控制 (对齐方式) */
.segmented-control {
  display: flex;
  background-color: #fff;
  border-radius: 0;
  padding: 4rpx;
  border: 3rpx solid #000;
  box-shadow: 4rpx 4rpx 0 #000;
}

.segment {
  padding: 14rpx 32rpx;
  font-size: 28rpx;
  border-radius: 0;
  color: #000;
  transition: all 0.1s;
  flex: 1;
  text-align: center;
  font-weight: 700;
}

.segment.active {
  background-color: #ff6b6b;
  color: #000;
  font-weight: 900;
}

/* 设置项 */
.setting-group {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #000;
  margin-bottom: 20rpx;
  font-weight: 700;
}

.setting-item:last-child {
  margin-bottom: 0;
}

.setting-item.column {
  flex-direction: column;
  align-items: stretch;
  gap: 0;
}

.footer-settings {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 0;
  border: 3rpx solid #000;
  box-shadow: 4rpx 4rpx 0 #000;
}

.setting-label {
  font-size: 24rpx;
  color: #000;
  margin-bottom: 12rpx;
  font-weight: 700;
  text-transform: uppercase;
}

.footer-input {
  height: 70rpx;
  padding: 0 16rpx;
  background: #fff;
  border: 3rpx solid #000;
  border-radius: 0;
  font-size: 26rpx;
  color: #000;
  font-weight: 600;
}

.label-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.value-text {
  color: #4facfe;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.picker-box {
  background-color: #f1f5f9;
  padding: 14rpx 36rpx;
  border-radius: 12rpx;
  color: #334155;
  font-weight: 500;
  font-size: 28rpx;
}

/* 底部操作栏 */
.action-bar {
  padding: 30rpx 40rpx calc(30rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 1rpx solid #f1f5f9;
}

.primary-btn {
  background: #4ecdc4;
  color: #000;
  border-radius: 0;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
  font-size: 32rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  border: 4rpx solid #000;
  box-shadow: 8rpx 8rpx 0 #000;
  transition: all 0.1s;
  position: relative;
}

.primary-btn:active {
  transform: translate(4rpx, 4rpx);
  box-shadow: 4rpx 4rpx 0 #000;
}

.primary-btn.loading {
  opacity: 0.7;
}

.bottom-safe-area {
  height: 150rpx;
}

