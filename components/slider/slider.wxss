/* components/slider/slider.wxss - Brutalism Style */

.slider-component {
  width: 100%;
}

.slider-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.slider-label {
  font-size: 28rpx;
  color: #000;
  font-weight: 900;
  text-transform: uppercase;
}

.slider-value {
  font-size: 28rpx;
  color: #000;
  font-weight: 900;
  background: #ffe66d;
  padding: 4rpx 16rpx;
  border: 3rpx solid #000;
}